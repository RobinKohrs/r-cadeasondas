library(tidyverse)
library(here)
library(glue)
library(sf)
library(rajudas)
library(jsonlite)
library(stars)
library(exactextractr)
# data_spots --------------------------------------------------------------
path_spots = here("output/all_spots/all_spots.csv")
data_spots = read_csv(path_spots)
geo_spots = data_spots %>% st_as_sf(coords=c("lon", "lat"), crs=4326)
# data bathy --------------------------------------------------------------
path_bathy = here("data_raw/GEBCO_2023_sub_ice_topo.nc")
stars_bathy = stars::read_ncdf(path_bathy, proxy = T)
i = 1
row = geo_spots[i, ]
buffer = st_buffer(row, dist=buffer_meter)
# extract from the super large raster
geo_bathy_buffer = stars_bathy[buffer, ]
# for each point extract 1 degree -----------------------------------------
buffer_meter = 200000
row = geo_spots[i, ]
buffer = st_buffer(row, dist=buffer_meter)
# extract from the super large raster
geo_bathy_buffer = stars_bathy[buffer, ]
# write to tempfile
tf = tempfile()
write_sf(geo_bathy_buffer, tf)
write_sf(buffer, tf)
tf
# write to tempfile
tf = glue("{tempfile()}.geojson")
tf
write_sf(buffer, tf)
row
id = row$id
# cropped raster path
op_cropped_bath_spot = makePath(here(glue("data_raw/cropped_bathy_spot/{id}.tif")))
op_cropped_bath_spot
# cropped raster path
op_cropped_bathy_spot = makePath(here(glue("data_raw/cropped_bathy_spot/{id}.tif")))
# extract raster
cmd = glue("gdalwarp -of GTiff -cutline {tf}  {path_bathy} {op}")
# extract raster
cmd = glue("gdalwarp -of GTiff -cutline {tf}  {path_bathy} {op_cropped_bathy_spot}")
cmd
# cropped raster path
op_cropped_bathy_spot = makePath(here(glue("data_raw/cropped_bathy_spot/{id}.tif")))
# extract raster
cmd = glue("gdalwarp -of GTiff -cutline {tf}  {path_bathy} {op_cropped_bathy_spot}")
system(cmd)
# extract raster
cmd = glue("gdalwarp -s_srs 'EPSG:4326' -of GTiff -cutline {tf}  {path_bathy} {op_cropped_bathy_spot}")
system(cmd)
# cropped raster path
op_cropped_bathy_spot = makePath(here(glue("data_raw/cropped_bathy_spot/bathy_{id}.tif")))
# extract raster
cmd = glue("gdalwarp -s_srs 'EPSG:4326' -of GTiff -cutline {tf}  {path_bathy} {op_cropped_bathy_spot}")
cmd
buffer
write_sf(buffer, here("data_raw/buffer.geojson"))
write_sf(buffer, here("data_raw/buffer.geojson"))
mapview::mapview(buffer)
i
row = geo_spots[i, ]
id = row$id
buffer = st_buffer(row, dist=buffer_meter)
# write to tempfile
tf = glue("{tempfile()}.geojson")
write_sf(buffer, tf)
# cropped raster path
op_cropped_bathy_spot = makePath(here(glue("data_raw/cropped_bathy_spot/bathy_{id}.tif")))
if(file.exists(op_cropped_bathy_spot)){
next
}
# extract raster
cmd = glue("gdalwarp -s_srs 'EPSG:4326' -of GTiff -cutline {tf} -crop_to_cutline {path_bathy} {op_cropped_bathy_spot}")
system(cmd)
# for each point extract 1 degree -----------------------------------------
buffer_meter = 200000
for(i in seq_along(1:nrow(geo_spots))){
print(i)
row = geo_spots[i, ]
id = row$id
